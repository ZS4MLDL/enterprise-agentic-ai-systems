# ── Runtime mode ──────────────────────────────────────────────────────────────
# student   → SQLite, Chroma, in-memory queue, local secrets, console tracing
# enterprise → PostgreSQL, pgvector, Redis, Vault/SOPS, Langfuse/OTel
MODE=student

# ── LLM / OpenRouter ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model per cost tier
MODEL_CHEAP=openai/gpt-4o-mini
MODEL_DEFAULT=openai/gpt-4o
MODEL_POWERFUL=anthropic/claude-sonnet-4-6

# ── Database ──────────────────────────────────────────────────────────────────
# student mode
SQLITE_PATH=./data/app.db

# enterprise mode — matches Docker Compose postgres service credentials
DATABASE_URL=postgresql://aiuser:aipassword@localhost:5432/enterprise_ai
POSTGRES_USER=aiuser
POSTGRES_PASSWORD=aipassword
POSTGRES_DB=enterprise_ai

# ── Vector store ──────────────────────────────────────────────────────────────
# student: Chroma (local)
CHROMA_PERSIST_DIR=./data/chroma

# enterprise: pgvector (uses DATABASE_URL above)

# ── Queue ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Secrets (enterprise) ──────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# ── Observability ─────────────────────────────────────────────────────────────
# enterprise: Langfuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Document storage ──────────────────────────────────────────────────────────
# student: local disk
DOCUMENT_STORE_PATH=./data/documents

# enterprise: Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=enterprise-ai-docs
